APP_NAME=QR-Attend API
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=True

API_V1_PREFIX=/api/v1

SECRET_KEY=change-me-in-production

# Option 1: use a single DATABASE_URL
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/qr_attend

# Option 2: use individual DB settings
DB_HOST=localhost
DB_PORT=5432
DB_NAME=qr_attend
DB_USER=postgres
DB_PASSWORD=postgres

# Do not use * outside local development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Path to Firebase service account JSON file
FIREBASE_CREDENTIALS_PATH=

QR_IMAGE_DIR=storage/qr_codes
DEFAULT_QR_VALIDITY_MINUTES=15
DEFAULT_GEOFENCE_RADIUS_METERS=100